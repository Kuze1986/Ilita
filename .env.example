# Ilita Core — Environment Variables
# Copy to .env and populate before running

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Internal NEXUS services
KUZE_INTERNAL_URL=https://kuze-core.up.railway.app
BIOLOOP_INTERNAL_URL=https://bioloop-core.up.railway.app

# Ilita config
ILITA_INSTANCE_KEY=primary
SYNC_INTERVAL_HOURS=24
EXPLORATION_INTERVAL_HOURS=6
# Conversation continuity fallback window when client omits priorMessages
SESSION_WINDOW_MINUTES=60
# Max chars of loaded history sent to model; oldest message pairs dropped first
MAX_HISTORY_CHARS=120000

# Server
PORT=3000
NODE_ENV=production

# Security
INTERNAL_API_KEY=your_internal_api_key
